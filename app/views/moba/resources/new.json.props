json.resourceName @resource_class.human_name
json.resourceKey params[:resource_id]

json.fields @fields

json.belongsToOptions do
  @belongs_to_options.each do |field_name, options|
    json.set! field_name do
      json.array! options do |opt|
        json.id opt[:id]
        json.label opt[:label]
      end
    end
  end
end

json.record do
  json.id nil
  @fields.each do |field|
    json.set! field[:name], @record.send(field[:attribute])
  end
end

json.errors @errors
