json.resourceName @resource_class.plural_human_name
json.resourceKey params[:resource_id]
json.singularName @resource_class.human_name

json.fields @fields
json.filters @filters
json.sort @sort
json.direction @direction

json.pagination do
  json.currentPage @page
  json.totalPages @total_pages
  json.totalCount @total_count
  json.perPage @per_page
end

json.records do
  json.array! @records do |record|
    json.id record.id
    @fields.each do |field|
      json.set! field[:name], record.send(field[:attribute])
    end
  end
end
