{
  "name": "moba",
  "version": "0.1.0",
  "description": "Modern admin panel for Rails using React and Superglue",
  "main": "app/javascript/moba/application.tsx",
  "scripts": {
    "build": "esbuild app/javascript/moba/application.tsx --bundle --outfile=app/assets/builds/moba.js --format=esm --target=es2020 --sourcemap --alias:@moba=./app/javascript/moba --alias:@views=./app/views/moba",
    "build:css": "npx @tailwindcss/cli -i app/assets/stylesheets/moba/application.css -o app/assets/builds/moba.css --minify",
    "watch": "esbuild app/javascript/moba/application.tsx --bundle --outfile=app/assets/builds/moba.js --format=esm --target=es2020 --sourcemap --watch --alias:@moba=./app/javascript/moba --alias:@views=./app/views/moba",
    "watch:css": "npx @tailwindcss/cli -i app/assets/stylesheets/moba/application.css -o app/assets/builds/moba.css --watch"
  },
  "keywords": [
    "rails",
    "admin",
    "react",
    "superglue",
    "typescript"
  ],
  "author": "Luca Castelnovo <luca@monade.io>",
  "license": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-table": "^8.21.3",
    "@thoughtbot/superglue": "^1.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.3.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.8.2"
  }
}
